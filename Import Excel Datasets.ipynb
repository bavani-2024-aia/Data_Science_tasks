    "!pip install openpyxl\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "data = {'Product': ['Laptop', 'Mouse', 'Monitor'], \n",
    "        'Price': [2000, 3500, 77000, 55000] }\n",
    "pd.DataFrame(data).to_excel('sales.xlsx', index=False)\n",
    "\n",
    "\n",
    "df_excel = pd.read_excel('sales.xlsx')\n",
    "\n",
    "print(\" Imported Excel Data \")\n",
    "print(df_excel)\n"
   ]
