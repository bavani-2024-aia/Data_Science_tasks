   "source": [
    "import pandas as pd\n",
    "\n",
    "\n",
    "sales_data = {\n",
    "    'Customer': ['Bavani', 'Rohan', 'Bavani'],\n",
    "    'Amount': [50000, 2000, 50000]\n",
    "}\n",
    "df = pd.DataFrame(sales_data)\n",
    "print(\"Before Cleaning:\\n\", df)\n",
    "\n",
    "\n",
    "df_clean = df.drop_duplicates()\n",
    "print(\"\\nAfter Cleaning Duplicates:\\n\", df_clean)\n"
   ]
