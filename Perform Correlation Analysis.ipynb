    "import pandas as pd\n",
    "\n",
    "data = {\n",
    "    \"Hours\": [2, 4, 6, 8, 10],\n",
    "    \"Marks\": [40, 55, 70, 85, 95]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "correlation = df[\"Hours\"].corr(df[\"Marks\"])\n",
    "\n",
    "print(\"Correlation:\", correlation)"
   ]
  }
