    "import matplotlib.pyplot as plt\n",
    "\n",
    "marks = [45, 50, 55, 60, 65, 70, 72, 75, 80, 82, 85, 90, 95]\n",
    "\n",
    "plt.hist(marks, bins=5)\n",
    "\n",
    "plt.title(\"Histogram of Student Marks\")\n",
    "plt.xlabel(\"Marks\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "\n",
    "plt.show()"
