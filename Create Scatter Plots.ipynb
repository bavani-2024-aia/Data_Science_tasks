   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "hours = [2, 4, 6, 8, 10]\n",
    "marks = [40, 55, 70, 85, 95]\n",
    "\n",
    "plt.scatter(hours, marks)\n",
    "\n",
    "plt.title(\"Hours Studied vs Marks\")\n",
    "plt.xlabel(\"Hours Studied\")\n",
    "plt.ylabel(\"Marks\")\n",
    "\n",
    "plt.show()"
   ]
